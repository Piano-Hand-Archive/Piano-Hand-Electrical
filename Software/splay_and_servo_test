from machine import Pin, I2C
import time
import struct

# --- PCA9685 Driver ---
class PCA9685:
    def __init__(self, i2c, addr=0x40):
        self.i2c = i2c
        self.addr = addr
        # Reset and Sleep
        self.i2c.writeto_mem(self.addr, 0x00, b'\x10')
        # Prescale for ~50Hz (Oscillator is typically 25MHz)
        # 121 (0x79) is standard, but some clones prefer 122 (0x7A)
        self.i2c.writeto_mem(self.addr, 0xFE, b'\x79')
        # Wake
        self.i2c.writeto_mem(self.addr, 0x00, b'\x00')
        time.sleep_ms(10)
        # Auto-increment
        self.i2c.writeto_mem(self.addr, 0x00, b'\xA0')

    def set_pwm(self, channel, on, off):
        reg = 0x06 + 4 * channel
        data = struct.pack('<HH', on, off)
        self.i2c.writeto_mem(self.addr, reg, data)

    def set_servo_us(self, channel, pulse_us):
        # 20ms period (50Hz), 4096 steps
        ticks = int(pulse_us * 4096 / 20000)
        self.set_pwm(channel, 0, ticks)

# --- Servo wrapper ---
class Servo:
    def __init__(self, pca, channel, max_angle=270, min_us=500, max_us=2500):
        self.pca = pca
        self.channel = channel
        self.max_angle = max_angle
        self.min_us = min_us
        self.max_us = max_us
        # Match this to your starting position in main loop
        self.current_angle = 90

    def go_to(self, angle):
        """Move servo to a specific angle and update tracking."""
        angle = max(0, min(self.max_angle, angle))
        pulse_us = self.min_us + (angle / self.max_angle) * (self.max_us - self.min_us)
        self.pca.set_servo_us(self.channel, pulse_us)
        self.current_angle = angle
        print(f"Ch {self.channel} -> {angle}°")

    def move_forward_15(self, hold_time=0.5):
        target = min(self.max_angle, self.current_angle + 15)
        self.go_to(target)
        time.sleep(hold_time)

    def move_back_15(self, hold_time=0.5):
        target = max(0, self.current_angle - 15)
        self.go_to(target)
        time.sleep(hold_time)

# --- Initialize I2C ---
i2c = I2C(0, sda=Pin(21), scl=Pin(22), freq=400000)
pca = PCA9685(i2c)

# --- Initialize 5 S51 Servos ---
# Using 135 as mid-point for a 270 degree servo
servos = [Servo(pca, c, max_angle=270) for c in [0, 1, 2, 3, 6]]

print("=== Initializing: Staggered Start ===")
# Moving all at once causes the LM2596 to spasm. 
# We move them one by one to their mid-point (135).
for s in servos:
    s.go_to(90)
    time.sleep(10) # Give the buck converter 500ms to recover

time.sleep(10)

print("=== Starting Test Loop ===")
for s in servos:
    print(f"Testing channel {s.channel}...")
    
    # Step 1: Forward 15 (135 -> 150)
    s.move_forward_15(hold_time=10)
    time.sleep(10) # Small gap between individual movements
    
    # Step 2: Back 15 (150 -> 135)
    s.move_back_15(hold_time=10)
    time.sleep(10)

print("=== Test complete ===")
