# --- PCA9685 Driver ---
class PCA9685:
    def __init__(self, i2c, addr=0x40, freq=50):
        self.i2c = i2c
        self.addr = addr
        self.freq = freq
        #  and Sleep
        self.i2c.writeto_mem(self.addr, 0x00, b'\x10')
            time.sleep_ms(5)
        # Prescale for ~50Hz (Oscillator is typically 25MHz)
        # 121 (0x79) is standard, but some clones prefer 122 (0x7A)
        self.i2c.writeto_mem(self.addr, 0xFE, b'\x79')
        # Wake
        self.i2c.writeto_mem(self.addr, 0x00, b'\x00')
        time.sleep_ms(5)
        # Auto-increment
        self.i2c.writeto_mem(self.addr, 0x00, b'\xA0')

    def set_pwm(self, channel, on, off):
        '''reg = 0x06 + 4 * channel
        data = struct.pack('<HH', on, off)
        self.i2c.writeto_mem(self.addr, reg, data)'''
        if channel < 0 or channel > 15:
            return
        reg = 0x06 + 4 * channel
        self.i2c.writeto_mem(self.addr, reg, bytes([
                on & 0xFF, (on >> 8) & 0xFF, off & 0xFF, (off >> 8) & 0xFF]))

    def set_servo_us(self, channel, pulse_us):
        # 20ms period (50Hz), 4096 steps
        ticks = int(pulse_us * 4096 / 20000)
        self.set_pwm(channel, 0, ticks)

# --- Servo wrapper ---
class Servo:
    def __init__(self, pca, channel, max_angle=270, min_us=500, max_us=2500):
        self.pca = pca
        self.channel = channel
        self.max_angle = max_angle
        self.min_us = min_us
        self.max_us = max_us
        # Match this to your starting position in main loop
        self.current_angle = 90

    def go_to(self, angle):
        """Move servo to a specific angle and update tracking."""
        angle = max(0, min(self.max_angle, angle))
        pulse_us = self.min_us + (angle / self.max_angle) * (self.max_us - self.min_us)
        self.pca.set_servo_us(self.channel, pulse_us)
        self.current_angle = angle
        print(f"Ch {self.channel} -> {angle}°")

    def move_forward_15(self, hold_time=0.5):
        target = min(self.max_angle, self.current_angle + 15)
        self.go_to(target)
        time.sleep(hold_time)

    def move_back_15(self, hold_time=0.5):
        target = max(0, self.current_angle - 15)
        self.go_to(target)
        time.sleep(hold_time)
#Read csv



def read_csv(filename):
    data = []
    with open(filename, 'r') as f:
        lines = f.readlines()

    for line in lines[1:]:  # skip header
        parts = line.strip().split(',')

        row = {
            "start_time": float(parts[0]),
            "key": parts[1],
            "thumb_pos": int(parts[2]),
            "finger": int(parts[3]),
            "hand": parts[4]
        }
        data.append(row)

    return data

def get_servo_angle(finger, thumb_pos, key):
    base_map = {
        1: 60,
        2: 75,
        3: 90,
        4: 105,
        5: 120
    }

    thumb_scale = 2.0  # tune this!

    # detect black keys
    note = key[:-1]
    if "#" in note:
        key_offset = 8
    else:
        key_offset = 0

    angle = base_map[finger] + thumb_scale * thumb_pos + key_offset
    return int(angle)

def play_right_hand(data, finger_to_servo):
    start_time = time.time()

    for row in data:
        if row["hand"] != "R":
            continue #skip left hand

        while time.time() - start_time < row["start_time"]:
            time.sleep_ms(1)

        finger = row["finger"]
        key = row["key"]
        thumb_pos = row["thumb_pos"]

        servo = finger_to_servo[finger]
        angle = get_servo_angle(finger, thumb_pos, key)
        
        print(f"Time {row['start_time']} -> Finger {finger}, Key {key}, Angle {angle}")
        servo.go_to(angle)
  

