#splay servo code which utilizes PCA9865

from machine import Pin, I2C
import time
from pca9685 import PCA9685  # make sure this library is on your ESP32

# --- I2C setup (ESP32 default pins) ---
i2c = I2C(0, scl=Pin(22), sda=Pin(21))

pca = PCA9685(i2c)
pca.freq(50)  # 50Hz for servos

# --- Servo settings ---
MIN_US = 500
MAX_US = 2500
PERIOD_US = 20000  # 20ms

# Convert angle to duty for PCA9685 (0–4095)
def angle_to_duty(angle):
    pulse = MIN_US + (angle / 270.0) * (MAX_US - MIN_US)
    duty = int((pulse / PERIOD_US) * 4095)
    return duty

def set_servo(channel, angle):
    duty = angle_to_duty(angle)
    pca.duty(channel, duty)

# --- Define your 5 servos (channels 0–4) ---
servos = [0, 1, 2, 3, 4]

# --- Move all servos to 0° initially ---
def initialize():
    for ch in servos:
        set_servo(ch, 0)
    print("Servos initialized")

initialize()

# --- Main loop: +15° then back to 0° ---
while True:
    # Move to 15°
    for ch in servos:
        set_servo(ch, 15)
    time.sleep(1)

    # Return to 0°
    for ch in servos:
        set_servo(ch, 0)
    time.sleep(1)
